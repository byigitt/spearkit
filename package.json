{
  "name": "spearkit",
  "version": "0.3.1",
  "description": "discord.js++ — a developer-experience-first Discord library. Drop-in compatible with discord.js, with ergonomic events, slash commands, and interactive components.",
  "type": "module",
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "byigitt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byigitt/spearkit.git"
  },
  "bugs": {
    "url": "https://github.com/byigitt/spearkit/issues"
  },
  "homepage": "https://github.com/byigitt/spearkit#readme",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "discord",
    "discord.js",
    "bot",
    "slash-commands",
    "interactions",
    "components"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "llms.txt",
    "llms-full.txt",
    "AGENTS.md",
    "docs",
    ".claude/skills"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "node e2e/live.mjs",
    "docs:llms": "node scripts/generate-llms.mjs",
    "prepublishOnly": "npm run docs:llms && npm run build"
  },
  "dependencies": {
    "discord.js": "^14.16.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}